# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── 235B Cloud model (api.ollama.com) ───────────────────────────────────────
# Used when the user selects "Qwen3-VL 235B (Cloud)" in the dropdown.
# AGENT_MODEL_URL and VL_MODEL_API_URL are the fallback for any model
# that does not have its own env var (baseUrlEnv).
AGENT_MODEL_URL=https://api.ollama.com
AGENT_API_KEY=your-ollama-cloud-api-key
AGENT_MODEL_NAME=qwen3-vl:235b-cloud

VL_MODEL_API_URL=https://api.ollama.com
VL_MODEL_API_KEY=your-ollama-cloud-api-key
VL_MODEL_NAME=qwen3-vl:235b-cloud

AGENT_MAX_ITERATIONS=12
AGENT_TEMPERATURE=0.2

# ─── 8B Local model (Ollama) ─────────────────────────────────────────────────
# Used when the user selects "Qwen3-VL 8B (Local)" in the dropdown.
# LOCAL DEV:    leave blank → falls back to the model's default http://localhost:11434
# RUNPOD DEMO:  set to https://<pod-id>-11434.proxy.runpod.net
LOCAL_OLLAMA_URL=

# ─── Python FreeCAD microservice ─────────────────────────────────────────────
# LOCAL DEV:    http://localhost:8001
# RUNPOD DEMO:  https://<pod-id>-8001.proxy.runpod.net
PYTHON_SERVICE_URL=http://localhost:8001

# ─── UI display ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENT_MODEL=qwen3-vl:235b-cloud
