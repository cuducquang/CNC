# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── vLLM inference endpoint (OpenAI-compatible) ─────────────────────────────
# Points to the vLLM server serving Qwen3-VL-32B-Thinking-FP8.
# LOCAL DEV:    http://localhost:11434  (run vLLM locally)
# RUNPOD:       https://<pod-id>-11434.proxy.runpod.net
LOCAL_OLLAMA_URL=https://<pod-id>-11434.proxy.runpod.net

# ─── Vision model ID ─────────────────────────────────────────────────────────
# Full path as reported by vLLM /v1/models (GET /v1/models to verify).
VISION_MODEL=/workspace/models/Qwen3-VL-32B-Thinking-FP8

# ─── Timeouts ────────────────────────────────────────────────────────────────
# 0 = unlimited. The 32B thinking model can take 30-120s per page.
VISION_TIMEOUT_MS=0

# ─── Python FreeCAD microservice ─────────────────────────────────────────────
# LOCAL DEV:    http://localhost:8001
# RUNPOD:       https://<pod-id>-8001.proxy.runpod.net
PYTHON_SERVICE_URL=http://localhost:8001
