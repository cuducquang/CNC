# ──────────────────────────────────────────────────────────────────────────────
# Approach 1 Python service (server_llm.py) — LLM-per-step pipeline only.
# No FreeCAD / poppler needed; all geometry analysis is done via text LLM.
# ──────────────────────────────────────────────────────────────────────────────
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev \
        # curl: used by the HEALTHCHECK probe
        curl ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

WORKDIR /app

# Install Python deps (cached layer — only rebuilds when requirements.txt changes)
COPY python/requirements.txt /app/python/requirements.txt
RUN pip3 install --no-cache-dir -r /app/python/requirements.txt

# Copy Python source
COPY python/ /app/python/

ENV HOST=0.0.0.0 \
    PORT=8002 \
    PYTHONPATH=/app/python

EXPOSE 8002

CMD ["python3", "/app/python/server_llm.py"]
