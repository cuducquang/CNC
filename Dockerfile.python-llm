# ──────────────────────────────────────────────────────────────────────────────
# Unified Python service (server.py) — both Approach 1 and Approach 2.
# Includes FreeCAD + poppler for the full pipeline.
# ──────────────────────────────────────────────────────────────────────────────
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        freecad \
        python3 python3-pip python3-dev \
        # poppler: PDF -> PNG conversion used by pipeline/approach2.py
        poppler-utils \
        # curl: used by the HEALTHCHECK probe
        curl ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

WORKDIR /app

# Install Python deps (cached layer — only rebuilds when requirements.txt changes)
COPY python/requirements.txt /app/python/requirements.txt
RUN pip3 install --no-cache-dir -r /app/python/requirements.txt

# Copy Python source
COPY python/ /app/python/

ENV HOST=0.0.0.0 \
    PORT=8001 \
    FREECAD_PATH=/usr/lib/freecad/lib \
    PYTHONPATH=/app/python

EXPOSE 8001

CMD ["python3", "/app/python/server.py"]
